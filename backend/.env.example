# HirePilot Backend

## Environment Variables
# Copy .env.example to .env and fill in your values

# Application
APP_NAME=HirePilot
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://hirepilot:hirepilot@localhost:5432/hirepilot
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# S3/MinIO
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=hirepilot-resumes
S3_REGION=us-east-1

# Encryption (for stored credentials)
CREDENTIAL_ENCRYPTION_KEY=generate-with-Fernet.generate_key()

# Rate Limiting
SCRAPING_RATE_LIMIT_PER_MINUTE=10
OUTREACH_RATE_LIMIT_PER_DAY=50
APPLICATION_RATE_LIMIT_PER_DAY=20

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# LaTeX
LATEX_COMPILER_PATH=/usr/bin/pdflatex
LATEX_COMPILE_TIMEOUT=30
